# Copy to .env and fill in. Streamlit will load via python-dotenv.

# Aliyun DashScope (Qwen + qwen3-vl-flash)
QWEN_API_KEY=

# OpenAI-compatible custom endpoint (optional)
CUSTOM_OPENAI_API_KEY=
CUSTOM_OPENAI_BASE_URL=

# Default provider when starting the UI: qwen | custom_openai
VSPLIT_DEFAULT_PROVIDER=qwen
